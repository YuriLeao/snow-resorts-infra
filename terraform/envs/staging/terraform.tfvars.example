# Copy to terraform.tfvars and adjust. Never commit real secrets.
region = "us-east-1"
azs    = ["us-east-1a", "us-east-1b"]

# Consolidated app image (push to ECR first), e.g.:
# app_image = "123456789012.dkr.ecr.us-east-1.amazonaws.com/snow-resorts/app:latest"

# Optional HTTPS cert (leave unset for plain HTTP during closed beta):
# certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx"
